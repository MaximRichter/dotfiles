#!/usr/bin/env bash

if [[ $# -eq 1 ]]; then
    selected=$1
else
    # Объединить сессии и директории в правильном порядке
    selected=$({
        tmux list-sessions -F "SESSION:#{session_name}" 2>/dev/null
        fd --type d --hidden --exclude .git . ~ --max-depth 3
    } | fzf)
fi

if [[ -z $selected ]]; then
    exit 0
fi

# Проверить, это сессия или директория
if [[ $selected == SESSION:* ]]; then
    # Убрать префикс SESSION:
    selected_name="${selected#SESSION:}"
    
    if [[ -z $TMUX ]]; then
        tmux attach -t "$selected_name"
    else
        tmux switch-client -t "$selected_name"
    fi
else
    # Это директория - обычная логика
    selected_name=$(basename "$selected" | tr . _)
    
    if ! tmux has-session -t="$selected_name" 2> /dev/null; then
        tmux new-session -ds "$selected_name" -c "$selected"
    fi
    
    if [[ -z $TMUX ]]; then
        tmux attach -t "$selected_name"
    else
        tmux switch-client -t "$selected_name"
    fi
fi
